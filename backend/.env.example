# Quick start (local, no full Docker):
#   docker compose up -d postgres redis   # start just the datastores
#   npm run dev                            # migrations auto-run on boot
#
# Host names differ by how you run:
#   - local `npm run dev`      -> use localhost (values below)
#   - full `docker compose up` -> use service names: @postgres / @redis
#     DATABASE_URL=postgresql://finpay:finpay@postgres:5432/finpay
#     REDIS_URL=redis://redis:6379

# Server
PORT=3000

# PostgreSQL connection string (schema migrations run automatically at startup)
DATABASE_URL=postgresql://finpay:finpay@localhost:5432/finpay

# Redis — REQUIRED (server won't boot without it; used by BullMQ queues/workers)
REDIS_URL=redis://localhost:6379

# JWT signing secret (auth tokens, OTP, password reset)
JWT_SECRET=

# OTP sender Gmail address (defaults to finpay.comp3900@gmail.com if unset).
# Auth uses APP_PASSWORD below.
OTP_FROM_EMAIL=

# Gmail app password for nodemailer (OTP + password reset emails)
APP_PASSWORD=

# Open Exchange Rates app id (currency exchange)
EXCHANGERATE_KEY=

# Cloudinary (image uploads)
CLOUDINARY_CLOUD=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

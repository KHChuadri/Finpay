# Server
PORT=3000

# PostgreSQL connection string
DATABASE_URL=postgresql://finpay:finpay@localhost:5432/finpay

# Redis (used by BullMQ queues/workers)
REDIS_URL=redis://localhost:6379

# JWT signing secret (auth tokens, OTP, password reset)
JWT_SECRET=

# SendGrid API key (OTP emails)
SENDGRID_API_KEY=

# Gmail app password for nodemailer (password reset emails)
APP_PASSWORD=

# Open Exchange Rates app id (currency exchange)
EXCHANGERATE_KEY=

# Cloudinary (image uploads)
CLOUDINARY_CLOUD=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=
